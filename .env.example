# ===============================
# 🌍 APP / RUNTIME
# ===============================

NODE_ENV=development

# (Opcional) Variáveis públicas (apenas se usadas no frontend)
NEXT_PUBLIC_APP_NAME=Processflow
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===============================
# 🗄️ SUPABASE (Frontend)
# ===============================

# Variáveis públicas (OK expor no browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===============================
# 🗄️ SUPABASE (Backend / Edge Functions / Scripts)
# ===============================

# Server only (NUNCA expor no browser)
# Nomes padrão (recomendados para Edge Functions)
PROJECT_URL=https://your-project.supabase.co
SERVICE_ROLE_KEY=your-service-role-key

# ===============================
# 🔐 WEBHOOKS (Edge Functions)
# ===============================

# Server only (NUNCA expor no browser)
WEBHOOK_SECRET=your-webhook-secret

# ===============================
# 🤖 OPENAI
# ===============================

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ===============================
# ⚙️ AI SETTINGS
# ===============================

AI_TIMEOUT_MS=10000
AI_MAX_RETRIES=2

# Rate limit (proteção de custo)
AI_RATE_LIMIT_WINDOW_SEC=10
AI_DAILY_LIMIT=50

# Truncation limits
AI_MAX_CONTEXT_CHARS=1500
AI_MAX_PROMPT_CHARS=1500
AI_MAX_LEAD_FIELD_CHARS=200

# ===============================
# 🧠 FEATURE FLAGS
# ===============================

FEATURE_AI_ENABLED=true

# ===============================
# 📊 LOGGING
# ===============================

LOG_LEVEL=info
