# ===============================
# 🖥️ FRONTEND (Next.js)
# ===============================
#
# Copie este arquivo para `frontend/.env.local` e substitua pelos seus valores reais.
# IMPORTANTE: somente variáveis com prefixo `NEXT_PUBLIC_` são expostas no browser.
# Nunca coloque secrets (service role, webhook secret, OpenAI key, etc.) com `NEXT_PUBLIC_`.
#

# Público (vai para o bundle do browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only: usado para proxyar chamadas admin às Edge Functions (não expor no browser)
WEBHOOK_SECRET=your-webhook-secret

